{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "uijona": {
      "projectType": "library",
      "root": "projects/uijona",
      "sourceRoot": "projects/uijona/src",
      "prefix": "j",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/uijona/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/uijona/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/uijona/tsconfig.spec.json"
          }
        },
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": "projects/uijona/.storybook",
            "browserTarget": "uijona:build",
            "compodoc": true,
            "compodocArgs": ["-e", "json", "-d", "projects/uijona"],
            "port": 6006,
            "styles": ["projects/uijona/src/styles/uijona.css"]
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": "projects/uijona/.storybook",
            "browserTarget": "uijona:build",
            "compodoc": true,
            "compodocArgs": ["-e", "json", "-d", "projects/uijona"],
            "outputDir": "storybook-static",
            "styles": ["projects/uijona/src/styles/uijona.css"]
          }
        }
      }
    },
    "devol": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:class": {
          "skipTests": true
        },
        "@schematics/angular:component": {
          "skipTests": true
        },
        "@schematics/angular:directive": {
          "skipTests": true
        },
        "@schematics/angular:guard": {
          "skipTests": true
        },
        "@schematics/angular:interceptor": {
          "skipTests": true
        },
        "@schematics/angular:pipe": {
          "skipTests": true
        },
        "@schematics/angular:resolver": {
          "skipTests": true
        },
        "@schematics/angular:service": {
          "skipTests": true
        }
      },
      "root": "projects/devol",
      "sourceRoot": "projects/devol/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/devol/src/main.ts",
            "tsConfig": "projects/devol/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/devol/public"
              }
            ],
            "styles": ["projects/devol/src/styles.css"]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "devol:build:production"
            },
            "development": {
              "buildTarget": "devol:build:development"
            }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
